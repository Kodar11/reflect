{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "../../dist-electron",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["../../types", "node"],
  "skipLibCheck": true
  },
  "include": [
    "../electron/main.ts",
    "../electron/preload.cts",
    "../electron/util.ts",
    "../electron/pathResolver.ts",
    "../tracker/**/*.ts",
    "../database/**/*.ts",
    "../models/**/*.ts"
  ],
  "exclude": ["**/*.test.ts"]
}
